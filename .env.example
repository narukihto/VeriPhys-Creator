# --- 🛡️ VERIPHYS CORE INFRASTRUCTURE CONFIGURATION ---

# 1. Blockchain Network Settings
# The deployed IntegrityLedger contract address (0x...)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Provider URL (Alchemy, Infura, or Local Node like http://localhost:8545)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Your Wallet Private Key (Use a dedicated 'hot wallet' for anchoring)
# WARNING: Ensure this file is added to .gitignore
PRIVATE_KEY=your_private_key_here

# 2. Rust Engine (Axum 0.7) Settings
# Port for the REST API (Default: 3000)
SERVER_PORT=3000

# Path to the local registry (Audit Trail) file
REGISTRY_PATH=./registry.txt

# 3. Protocol Security & Monitoring
# Logging level: info (Production), debug (Development), error (Critical)
RUST_LOG=info

# Maximum file upload size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# 4. JWT & Encryption (For future auth layers)
APP_SECRET=generate_a_long_random_string_here
