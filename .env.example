# --- Blockchain Configuration ---
# The deployed smart contract address on the network (Ethereum/BSC/etc.)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Your wallet private key (NEVER share the real key)
PRIVATE_KEY=your_private_key_here

# Provider URL (Infura, Alchemy, or a local node like Anvil/Hardhat)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# --- Rust Engine Settings ---
# Port for the Axum API server
SERVER_PORT=3000

# Path to the local registry file
REGISTRY_PATH=./registry.txt

# --- Security Settings ---
# Secret key for JWT or session management (if applicable)
APP_SECRET=your_app_secret_logic
