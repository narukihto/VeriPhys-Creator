# --- 🛡️ VERIPHYS CORE: ENVIRONMENT TEMPLATE ---
# Copy this file to .env and fill in your actual credentials.

# 1. Blockchain Network Settings
# The deployed IntegrityLedger contract address (0x...)
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Provider URL (e.g., Alchemy, Infura, or local node like http://localhost:8545)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Your Wallet Private Key (MUST be kept secret)
# Use a dedicated 'hot wallet' for automated anchoring.
PRIVATE_KEY=your_private_key_here

# 2. Rust Engine (Axum 0.7) Settings
# Port for the REST API (Standard: 3000)
SERVER_PORT=3000

# Path to the local registry (Audit Trail) file
REGISTRY_PATH=./registry.txt

# 3. Protocol Performance & Logging
# Logging level: info (Default), debug (Dev), error (Critical)
RUST_LOG=info

# Maximum file upload size in bytes (e.g., 10MB = 10485760)
MAX_FILE_SIZE=10485760

# 4. Security & Authentication
# Random string for cryptographic signing or future JWT logic
APP_SECRET=replace_with_a_long_random_hash
